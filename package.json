{
  "name": "synnerdata-api-b",
  "version": "1.0.50",
  "scripts": {
    "dev": "bun db:start && bun run --watch src/index.ts",
    "build": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile server ./src/index.ts",
    "start": "NODE_ENV=production ./server",
    "test": "NODE_ENV=test bun test --env-file .env",
    "test:coverage": "NODE_ENV=test bun test --env-file .env --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "db:push": "bun --env-file .env --bun drizzle-kit push",
    "db:studio": "bun --env-file .env --bun drizzle-kit studio",
    "db:generate": "bun --env-file .env --bun drizzle-kit generate",
    "db:migrate": "bun --env-file .env --bun drizzle-kit migrate",
    "db:seed": "bun --env-file .env src/db/seeds/plans.ts",
    "db:start": "docker compose up -d",
    "db:watch": "docker compose up",
    "db:stop": "docker compose stop",
    "db:down": "docker compose down",
    "prepare": "husky",
    "commit": "cz",
    "secrets:check": "secretlint \"**/*\"",
    "lint:types": "bun x tsc --noEmit",
    "lint:check": "bun x ultracite check",
    "lint:fix": "bun x ultracite fix",
    "lint": "bun run lint:types && bun run lint:check",
    "check": "bun run lint && bun run secrets:check",
    "ci": "bun run check && bun run test"
  },
  "dependencies": {
    "@bogeychan/elysia-logger": "^0.1.10",
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/cron": "^1.4.1",
    "@elysiajs/openapi": "^1.4.11",
    "better-auth": "^1.4.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.0",
    "elysia": "latest",
    "elysia-rate-limit": "^4.4.2",
    "nodemailer": "^7.0.11",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@faker-js/faker": "^10.1.0",
    "@playwright/test": "^1.57.0",
    "@secretlint/secretlint-rule-preset-recommend": "^11.2.5",
    "@types/nodemailer": "^7.0.4",
    "@types/pg": "^8.15.6",
    "bun-types": "latest",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "drizzle-kit": "^0.31.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "secretlint": "^11.2.5",
    "tsx": "^4.21.0",
    "ultracite": "6.3.10"
  },
  "module": "src/index.js",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "bun x ultracite fix"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
